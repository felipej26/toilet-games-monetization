# Firebase (client)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase (server)
FIREBASE_PROJECT_ID=
# Local development: prefer a JSON file path over inline JSON
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json
# Optional fallback (JSON string of service account key)
FIREBASE_SERVICE_ACCOUNT_KEY=

# AdMob
ADMOB_PUBLISHER_ID=pub-9622382276517695
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Comma-separated list of allowed Google account emails
ALLOWED_EMAILS=seu-email@gmail.com

# Local dev only — corporate proxy / SSL inspection (pick one if you get SELF_SIGNED_CERT_IN_CHAIN)
# NODE_EXTRA_CA_CERTS=/path/to/corporate-ca.pem
# NODE_TLS_REJECT_UNAUTHORIZED=0
